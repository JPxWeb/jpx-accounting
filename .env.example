ACCOUNTING_RUNTIME_MODE=demo
# Comma-separated browser origins allowed to call the API directly when runtime mode is `normal` (ignored in `demo`, which uses open CORS).
ACCOUNTING_CORS_ORIGINS=
# E2E / local only: lets POST /api/testing/reset in demo erase the in-memory store (never enable in deployed normal mode).
# ALLOW_TEST_RESET=true
NEXT_PUBLIC_ACCOUNTING_RUNTIME_MODE=demo
ACCOUNTING_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=/api-proxy
NEXT_PUBLIC_DISABLE_SW=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=gpt-5-mini
# Signs advisor tool-approval round trips (AI SDK toolApproval). A demo default
# exists in code; deployed normal mode MUST set its own secret.
ADVISOR_TOOL_APPROVAL_SECRET=
# --- Supabase (ledger persistence + auth) -----------------------------------
# Direct Postgres URL (port 5432) or Supavisor session-mode URL — required to enable PostgresLedgerStore in normal mode.
SUPABASE_DB_URL=
# Set to "true" only when SUPABASE_DB_URL points at the Supavisor transaction-mode pooler (port 6543).
# Disables postgres-js prepared statements (transaction mode does not support them).
SUPABASE_POOLER_TRANSACTION_MODE=false
# Optional: when set, mutating /api/* routes require a JWT verifiable against this JWKS endpoint.
# Typical Supabase value: ${SUPABASE_URL}/auth/v1/keys (when Supabase Auth is wired — currently deferred).
SUPABASE_JWKS_URL=
# Optional, comma-separated: asymmetric algorithms the JWKS verifier accepts (e.g. RS256,ES256).
# Defaults to RS256,ES256 when unset — Supabase's newer projects sign with ES256, so a bare RS256
# allowlist would 401 every legitimate user on those projects.
SUPABASE_JWT_ALGS=
# --- Azure Storage (evidence blobs) -----------------------------------------
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=evidence
# Web CSP allowance for direct-to-Azure SAS traffic (browser PUTs via connect-src, read-SAS previews via img-src/frame-src).
# Set to the storage origin, e.g. https://<account>.blob.core.windows.net — must be present at web BUILD time. Unset keeps the strict same-origin CSP (demo/stub uploads).
NEXT_PUBLIC_AZURE_STORAGE_ORIGIN=
# --- Azure Document Intelligence (OCR for receipts/invoices) ----------------
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=
