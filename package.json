{
  "name": "jpx-accounting",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm --filter @jpx-accounting/web --filter @jpx-accounting/api --parallel run dev",
    "dev:web": "corepack pnpm --filter @jpx-accounting/web dev",
    "dev:api": "corepack pnpm --filter @jpx-accounting/api dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "corepack pnpm -r typecheck",
    "typecheck:tests": "tsc --noEmit -p tests/tsconfig.json",
    "test:unit": "tsx --test \"tests/unit/**/*.test.ts\"",
    "test:integration": "tsx --test \"tests/integration/**/*.test.ts\"",
    "build": "corepack pnpm --filter @jpx-accounting/web build && corepack pnpm --filter @jpx-accounting/api build",
    "bundle:api": "esbuild services/api/src/index.ts --bundle --platform=node --format=cjs --outfile=api-deploy/server.cjs && node -e \"require('node:fs').writeFileSync('api-deploy/package.json', '{}')\"",
    "build:knowledge": "tsx scripts/build-knowledge-corpus.mjs",
    "ingest:knowledge": "tsx scripts/ingest-knowledge.mjs",
    "check:i18n": "node scripts/check-i18n-parity.mjs",
    "check": "corepack pnpm lint && corepack pnpm check:i18n && corepack pnpm format:check && corepack pnpm typecheck && corepack pnpm typecheck:tests && corepack pnpm test:unit && corepack pnpm build",
    "build:e2e": "cross-env NEXT_PUBLIC_ACCOUNTING_RUNTIME_MODE=demo NEXT_PUBLIC_API_BASE_URL=/api-proxy corepack pnpm build",
    "test:e2e": "corepack pnpm build:e2e && playwright test",
    "test:e2e:headed": "corepack pnpm build:e2e && playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:visual": "corepack pnpm build:e2e && playwright test tests/e2e/visual-regression.spec.ts",
    "test:e2e:visual:update": "corepack pnpm build:e2e && playwright test tests/e2e/visual-regression.spec.ts --update-snapshots",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,jsx,json,md,css,yml,yaml}": "prettier --write --ignore-unknown",
    "*.{ts,tsx,js,mjs,cjs,jsx}": "eslint --fix --no-warn-ignored"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "25.5.0",
    "cross-env": "^10.1.0",
    "esbuild": "0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "next": "16.2.0",
    "prettier": "^3.8.3",
    "sharp": "^0.35.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
