{
  "name": "jpx-accounting",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @jpx-accounting/web dev",
    "dev:api": "pnpm --filter @jpx-accounting/api dev",
    "typecheck": "pnpm -r typecheck",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "build": "pnpm --filter @jpx-accounting/web build && pnpm --filter @jpx-accounting/api build",
    "check": "pnpm typecheck && pnpm build",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:headed": "pnpm build && playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --fix --no-errors-on-unmatched",
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.{json,css,md}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.9",
    "@playwright/test": "^1.58.2",
    "@types/node": "25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
