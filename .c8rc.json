{
  "all": true,
  "include": ["packages/*/src/**", "services/api/src/**", "apps/web/lib/**"],
  "extension": [".ts", ".tsx"],
  "exclude": ["**/corpus.generated.ts", "**/*.d.ts", "**/.next/**", "**/node_modules/**"],
  "reporter": ["text", "lcov"],
  "reports-dir": "coverage",
  "check-coverage": true,
  "statements": 70,
  "lines": 70,
  "functions": 0,
  "branches": 0
}
