{
  "name": "@jpx-accounting/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node -e \"const{execSync:e}=require('child_process');try{const o=e('netstat -ano | findstr :3000 | findstr LISTENING',{encoding:'utf8'});const m=o.match(/LISTENING\\s+(\\d+)/);if(m)e('taskkill /PID '+m[1]+' /F')}catch{}\"",
    "dev": "next dev",
    "prebuild": "node -e \"const fs=require('fs'),p='public/sw.js',{execSync:e}=require('child_process');const h=e('git rev-parse --short HEAD',{encoding:'utf8'}).trim();fs.writeFileSync(p,fs.readFileSync(p,'utf8').replace('static-__BUILD_HASH__','static-'+h))\"",
    "postbuild": "node -e \"const fs=require('fs'),p='public/sw.js';fs.writeFileSync(p,fs.readFileSync(p,'utf8').replace(/static-[a-f0-9]{7,}/,'static-__BUILD_HASH__'))\"",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@jpx-accounting/api-client": "workspace:*",
    "@jpx-accounting/contracts": "workspace:*",
    "@jpx-accounting/reporting": "workspace:*",
    "@jpx-accounting/ui-tokens": "workspace:*",
    "@tanstack/react-query": "5.91.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "8.0.3",
    "lucide-react": "^1.7.0",
    "motion": "12.38.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^5.3.2",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  }
}
